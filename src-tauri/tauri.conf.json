{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PureMind",
  "version": "0.1.0",
  "identifier": "com.puremind.app",
  "build": {
    "beforeBuildCommand": "npm run build:next",
    "beforeDevCommand": "npm run dev:next",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "PureMind",
        "width": 1600,
        "minHeight": 600,
        "minWidth": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
